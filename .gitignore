# Raw source data (hundreds of MB of CSVs — kept locally only)
data/raw/
data/raw_gpa/

# NCES geocode cache ZIPs
data/nces_*.zip

# Combined admissions file (per-type files are used instead)
data/admissions.json
data/gpa.json

# Python processing scripts (not part of the website)
*.py
*.js
!app.js
!campus_scraper.js
!type_scraper.js
!type_campus_scraper.js
!gpa_scraper.js
!process_data.py
!process_gpa_data.py

# Node / scraper tooling
node_modules/
package*.json
playwright-report/

# Exceptions: nextjs-app is a full Next.js project and needs its own files tracked
!nextjs-app/**/*.js
!nextjs-app/**/*.ts
!nextjs-app/**/*.tsx
!nextjs-app/**/*.mjs
!nextjs-app/**/*.py
!nextjs-app/package.json
!nextjs-app/package-lock.json

# macOS
.DS_Store

